import paho.mqtt.client as mqtt      #MQTT 통신 기능을 위한 라이브러리 불러오기
import time                          #시간 지연 기능 사용
from gpiozero import LED             #GPIO LED 제어 클래스 불러오기
import threading                     #멀티스레드 기능 사용

# GPIO 핀 번호에 맞게 LED 객체 생성
greenLed = LED(16)                   #초록 LED를 GPIO 16번 핀 연결
blueLed = LED(20)                    #파랑 LED를 GPIO 20번 핀 연결
redLed = LED(21)                     #빨강 LED를 GPIO 21번 핀 연결

#MQTT 메시지를 수신했을 때 자동 실행되는 함수
def on_message(client, userdata, msg):

    #수신한 Topic 이름과 메시지 출력
    print(msg.topic + " " + str(msg.payload))

    #byte 형태 메시지를 문자열로 변환
    message = msg.payload.decode()

    #변환된 메시지 출력
    print(message)

    # 수신한 메시지에 따라 LED 제어
    if message == "green_on":
        greenLed.on()        #초록 LED 켜기

    elif message == "green_off":
        greenLed.off()       #초록 LED 끄기

    elif message == "blue_on":
        blueLed.on()           #파랑 LED 켜기

    elif message == "blue_off":
        blueLed.off()           #파랑 LED 끄기

    elif message == "red_on":
        redLed.on()            #빨강 LED 켜기

    elif message == "red_off":
        redLed.off()           #빨강 LED 끄기


 #MQTT 클라이언트 객체 생성
client = mqtt.Client()

#메시지 수신 시 실행할 함수 등록
client.on_message = on_message

#MQTT 브로커 IP 주소 설정
broker_address = "192.168.137.230"

#브로커에 연결
client.connect(broker_address)

#"led" Topic 구독
client.subscribe("led", 1)

#발행할 숫자 데이터 초기값
count = 0

#별도 스레드에서 실행할 송신 함수 정의
def send_thread():

    global count

    while True:

        #숫자 값 증가
        count = count + 1

        #hello Topic으로 숫자 데이터 발행
        client.publish("hello", str(count))

        #1초 대기
        time.sleep(1.0)


#송신 함수를 별도 스레드로 생성
task = threading.Thread(target=send_thread)

#스레드 실행
task.start()

# 프로그램 종료 없이 계속 메시지 수신
client.loop_forever()
